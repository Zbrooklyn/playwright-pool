    "accessibility-testing",
    "wcag",
    "axe-core",
    "visual-regression",
    "core-web-vitals",
    "responsive-testing",
    "dark-mode-testing",
    "seo-audit",
    "claude-code",
    "claude",
    "ai-browser",
    "ai-tools",
    "cursor",
    "windsurf",
    "automation",
    "testing"
  ],
